# Telegram Bot Credentials
BOT_TOKEN=your_telegram_bot_token_here

# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017/echomind_telegram

# Local Ollama AI Engine Settings
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Web Server Port
PORT=4000

# Webhook deployment configs (for production environment, leave blank for local long-polling)
# WEBHOOK_URL=https://your-bot-backend.railway.app
# WEBHOOK_SECRET=your_custom_webhook_secret_here
